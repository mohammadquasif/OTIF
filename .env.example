# ═══════════════════════════════════════════════════
# OTIF — Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ═══════════════════════════════════════════════════

# ── Application ─────────────────────────────────────
APP_NAME=OTIF
APP_VERSION=0.1.0
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ── Neon PostgreSQL (Skills Community Database) ─────
# Read-only role for pulling skills at startup
NEON_READ_URL=postgresql://otif_reader:<password>@ep-restless-bread-ahwsywcx.c-3.us-east-1.aws.neon.tech/neondb?sslmode=require

# Write role for updating skill confidence after session
NEON_WRITE_URL=postgresql://otif_writer:<password>@ep-restless-bread-ahwsywcx.c-3.us-east-1.aws.neon.tech/neondb?sslmode=require

# Owner role (for initial schema setup only)
NEON_OWNER_URL=postgresql://neondb_owner:<password>@ep-restless-bread-ahwsywcx.c-3.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── Local Storage ────────────────────────────────────
LOCAL_DB_PATH=./data/otif_local.db
UPLOADS_PATH=./data/uploads
EMBEDDINGS_PATH=./data/embeddings
PROJECTS_PATH=./data/projects

# ── AI Providers (all optional — Ollama works offline) ──
AI_PRIVACY_MODE=local_only
AI_DEFAULT_PROVIDER=ollama

# Ollama (local, free, private)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.3:latest

# DeepSeek (best price/performance for academic tasks)
DEEPSEEK_API_KEY=
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# OpenAI
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-5.5

# Google Gemini (great for long thesis documents)
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-3-pro

# Anthropic Claude (cloud, optional)
CLAUDE_API_KEY=
CLAUDE_DEFAULT_MODEL=claude-3-5-sonnet-latest

# ── Research API Keys (all free tiers available) ─────
# OpenAlex (optional - increases rate limit)
OPENALEX_EMAIL=your@email.com
OPENALEX_API_KEY=

# CORE API (free key at core.ac.uk)
CORE_API_KEY=

# Semantic Scholar (free at semanticscholar.org)
SEMANTIC_SCHOLAR_API_KEY=

# Unpaywall (just your email)
UNPAYWALL_EMAIL=your@email.com

# ── Skill Engine ──────────────────────────────────────
# How often to check Neon for skill updates (seconds)
SKILL_PULL_INTERVAL=3600
# Minimum confidence improvement to trigger a skill update push
SKILL_UPDATE_THRESHOLD=0.05
# Whether to contribute anonymous learning signals back to community
SKILL_CONTRIBUTE_ANONYMOUS=true

# ── CORS (for frontend) ──────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
